{
  "rewrites": [
    {
      "source": "/api/image/(.*)",
      "destination": "/api/image?slug=$1"
    },
    {
      "source": "/api/image",
      "destination": "/api/image"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/:slug([a-zA-Z0-9_-]+)",
      "destination": "/api/redirect?slug=:slug"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
